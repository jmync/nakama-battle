# NocoDB Cloud registration proxy (set these in Render env, and in a local .env for testing)
# Base URL of your NocoDB instance (Cloud default below)
NOCODB_BASE_URL=https://app.nocodb.com
# The table ID for your registrations table (NocoDB table > ... > "Copy Table ID")
NOCODB_TABLE_ID=
# A NocoDB API token (Account > Tokens > Create) — keep secret, server-only
NOCODB_TOKEN=
# Port (Render sets this automatically; default 3000 locally)
# PORT=3000
